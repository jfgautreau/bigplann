# ------------------------------------------------------------------
# Modele de variables d'environnement. Copier en `.env` et adapter.
# Le fichier `.env` ne doit JAMAIS etre commite (cf .gitignore).
# ------------------------------------------------------------------

# Base de donnees PostgreSQL
POSTGRES_USER=planning
POSTGRES_PASSWORD=change-me-en-prod
POSTGRES_DB=planning_usine

# URL utilisee par Prisma.
# - En conteneur web (compose) : host = "db" (nom du service).
# - En local hors conteneur    : host = "localhost".
DATABASE_URL=postgresql://planning:change-me-en-prod@db:5432/planning_usine?schema=public

# Secret de signature des sessions (cookie JWT). Min 32 caracteres aleatoires.
# Generer : `node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"`
SESSION_SECRET=remplace-moi-par-un-secret-aleatoire-de-32-caracteres-minimum

# Administrateur initial cree au demarrage (seed) s'il n'existe pas.
ADMIN_EMAIL=admin@usine.local
ADMIN_PASSWORD=Admin1234!
ADMIN_NAME=Administrateur
