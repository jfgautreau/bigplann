# ------------------------------------------------------------------
# Variables Supabase. Copier en `.env.local` (jamais commite) et remplir
# avec les valeurs du NOUVEAU projet Supabase (Dashboard > Project Settings).
# Sur Vercel : definir ces 3 variables dans Project Settings > Environment Variables.
# ------------------------------------------------------------------

# Project Settings > Data API > Project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Project Settings > API Keys > publishable / anon key (cote client, RLS active)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_xxx_ou_anon_key

# Project Settings > API Keys > service_role (SECRET, cote serveur uniquement,
# bypass la RLS). NE JAMAIS exposer cote client ni commiter.
SUPABASE_SERVICE_ROLE_KEY=service_role_secret_xxx
